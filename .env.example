# ── Database ─────────────────────────────────────────────────────────────────
# Pooled connection used by the Next.js application at runtime.
DATABASE_URL="postgres://USER:PASSWORD@pooled.db.prisma.io:5432/postgres?sslmode=require"
# Direct connection used only by Prisma Migrate, Studio, and admin tools.
DIRECT_URL="postgres://USER:PASSWORD@db.prisma.io:5432/postgres?sslmode=require"

# ── Auth ─────────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"
# Registration is closed by default in production. Set to "true" only while
# creating your own account, then remove.
ALLOW_REGISTRATION=""

# ── Plaid ────────────────────────────────────────────────────────────────────
PLAID_CLIENT_ID=""
PLAID_SECRET=""
PLAID_ENV="sandbox"   # sandbox | development | production

# ── Square ───────────────────────────────────────────────────────────────────
SQUARE_ACCESS_TOKEN=""
SQUARE_APP_ID=""
SQUARE_APP_SECRET=""
SQUARE_ENVIRONMENT="sandbox"   # sandbox | production
SQUARE_LOCATION_ID=""
# Required in production — webhooks are rejected without it (fail closed).
SQUARE_WEBHOOK_SIGNATURE_KEY=""
SQUARE_WEBHOOK_URL=""

# ── Inbound receipt email webhook (SendGrid/Mailgun) ─────────────────────────
# Random secret; include it in the webhook URL you configure at the provider:
#   https://<host>/api/email/inbound?token=<secret>
INBOUND_EMAIL_WEBHOOK_SECRET=""

# ── Background jobs (Vercel Cron) ────────────────────────────────────────────
# Vercel sends this automatically as a bearer token to cron routes.
CRON_SECRET=""

# ── Integration API (consumed by local-effort-app brain) ────────────────────
# Bearer token for /api/integration/v1/*. Generate a long random value.
INTEGRATION_API_TOKEN=""

# ── Receipt file storage ─────────────────────────────────────────────────────
# When set, receipts go to Vercel Blob; otherwise ./uploads/receipts (dev).
BLOB_READ_WRITE_TOKEN=""
